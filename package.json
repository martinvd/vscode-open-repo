{
  "name": "vscode-open-repo",
  "displayName": "Open Repo",
  "description": "VS Code extension starter",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "openRepo.helloWorld",
        "title": "Open Repo: Hello World"
      }
    ]
  },
  "scripts": {
    "compile": "bun esbuild.config.mjs",
    "watch": "bun esbuild.config.mjs --watch",
    "vscode:prepublish": "bun esbuild.config.mjs --production",
    "package": "vsce package --no-dependencies"
  },
  "packageManager": "bun@1.3.10",
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
