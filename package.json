{
  "name": "vscode-open-repo",
  "displayName": "Open Repo",
  "description": "Open the workspace Git remote on GitHub or GitLab in your browser from the status bar.",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Open Repo",
      "properties": {
        "openRepo.githubEnterpriseHosts": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9.-]+$"
          },
          "default": [],
          "description": "Extra hostnames treated as GitHub (GitHub Enterprise Server), e.g. git.company.com. github.com, *.github.com, and github.* are recognized by default."
        }
      }
    },
    "commands": [
      {
        "command": "openRepo.openRemote",
        "title": "Open Repo: Open remote repository in browser"
      }
    ]
  },
  "scripts": {
    "compile": "bun esbuild.config.mjs",
    "watch": "bun esbuild.config.mjs --watch",
    "vscode:prepublish": "bun esbuild.config.mjs --production",
    "package": "vsce package --no-dependencies"
  },
  "packageManager": "bun@1.3.10",
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
